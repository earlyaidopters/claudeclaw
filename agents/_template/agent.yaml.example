# Agent configuration
# Copy this folder, rename it, and fill in your values.
#
# Then add your bot token to .env:
#   MYAGENT_BOT_TOKEN=1234567890:AAFxxxxxxx
#
# Start with:
#   npm start -- --agent myagent

name: My Agent
description: What this agent does

# The env var name in .env that holds this agent's Telegram bot token.
# Create a bot via @BotFather in Telegram, paste the token into .env.
telegram_bot_token_env: MYAGENT_BOT_TOKEN

# Default model. Options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
# Users can override per-chat with /model in Telegram.
model: claude-sonnet-4-6

# Obsidian integration (optional).
# Assign folders from your vault so this agent auto-loads relevant context.
# obsidian:
#   vault: /path/to/your/obsidian/vault
#   folders:
#     - FolderA/
#     - FolderB/
#   read_only:
#     - Daily Notes/

# Voice agent / phone call capabilities (optional -- uncomment to enable)
# Note: "voice-agent" not "voice" -- voice.ts handles Telegram voice note transcription
# voice-agent:
#   enabled: true
#   phone_number: "+1XXXXXXXXXX"
#   elevenlabs_voice_id: "your-voice-id"
#   elevenlabs_model: "eleven_multilingual_v2"  # or "eleven_v3" for speech tags
#   personality: |
#     Voice-agent-specific personality adjustments here.
#   speech_tags: |                               # Only works with eleven_v3
#     <prosody rate="medium">{text}</prosody>
#   sip:
#     termination_url: "sip:user@provider.com"
#     username: "sip-username"
#     password_env: "SIP_PASSWORD"
#   twilio:
#     account_sid_env: "TWILIO_ACCOUNT_SID"
#     auth_token_env: "TWILIO_AUTH_TOKEN"
