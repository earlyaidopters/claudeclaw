.env

# Runtime data — NEVER commit. Contains WhatsApp/Slack messages,
# session tokens, conversation logs, and database files.
store/
workspace/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Migration state — local only
migrations/.applied.json

# Logs
*.log
/tmp/claudeclaw.*

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
.wwebjs_cache/

# Personal scripts — not for sharing
scripts/waste-reminder.sh

# Personal config — lives in CLAUDECLAW_CONFIG (default ~/.claudeclaw)
CLAUDE.md
agents/*/agent.yaml
agents/*/CLAUDE.md

# Skills install artifacts (managed by the `skills` CLI).
# Keep skills-lock.json tracked so installs are reproducible.
.agents/
.claude/skills/defuddle
.claude/skills/json-canvas
.claude/skills/obsidian-bases
.claude/skills/obsidian-cli
.claude/skills/obsidian-markdown

# Third-party CLI cloned for reference (has its own .git)
cli/

# Personal knowledge base / memory
memory/

# Generated dashboard HTML (rebuilt from src/dashboard-html.ts)
dashboard.html

# Personal task tracker
TASKS.md

# Machine-specific launchd plists (contain absolute home paths)
launchd/com.claudeclaw.tunnel.plist

# War Room (Python) local artifacts
warroom/.venv/
warroom/__pycache__/
warroom/**/__pycache__/
